yarn-debug.log
yarn-error.log
package-lock.json
yarn.lock
.pnpm-debug.log
.pnpm-error.log

# Expo
.expo/
dist/
web-build/
android/
ios/
*.apk
*.ipa

# TypeScript
*.tsbuildinfo

# Testing
coverage/
.nyc_output/

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# IDE
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store

# Temporary files
tmp/
temp/
*.tmp

# Expo build artifacts
.expo-shared/
expo-env.d.ts

